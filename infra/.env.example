# ─────────────────────────────────────────────────────────────────────────────
# ATC — Atlantic Core  |  Infrastructure Environment Variables
# Copy this file to infra/.env and fill in real values before deploying.
# NEVER commit infra/.env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=changeme_root
DB_PASSWORD=changeme_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── ATC API ───────────────────────────────────────────────────────────────────
# Must be at least 32 characters
ATC_API_TOKEN=changeme_api_token_min32chars
ATC_SERVER_TOKEN=changeme_server_token
ATC_SERVER_ID=atc-main-01

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
