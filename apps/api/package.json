{
  "name": "@atc/api",
  "version": "0.1.0",
  "private": true,
  "description": "ATC REST API server",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "db:migrate": "node dist/run-migrate.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@atc/cache": "workspace:*",
    "@atc/db": "workspace:*",
    "@atc/events": "workspace:*",
    "@atc/runtime-items": "workspace:*",
    "@atc/schemas": "workspace:*",
    "@atc/shared-types": "workspace:*",
    "@atc/telemetry": "workspace:*",
    "@atc/plugin-registry": "workspace:*",
    "@atc/plugin-state": "workspace:*",
    "@atc/plugin-runtime": "workspace:*",
    "@atc/plugin-runtime-api": "workspace:*",
    "@atc/iam": "workspace:*",
    "@atc/audit": "workspace:*",
    "@atc/principal-store": "workspace:*",
    "@atc/ledger": "workspace:*",
    "@atc/organization": "workspace:*",
    "@atc/commerce": "workspace:*",
    "@atc/jobs": "workspace:*",
    "@atc/law": "workspace:*",
    "@atc/dispatch": "workspace:*",
    "@atc/mdt": "workspace:*",
    "@atc/medical": "workspace:*",
    "@atc/ems-runtime": "workspace:*",
    "@atc/vehicle-runtime": "workspace:*",
    "@atc/property-runtime": "workspace:*",
    "@atc/combat-runtime": "workspace:*",
    "@atc/criminal-runtime": "workspace:*",
    "@atc/world-runtime": "workspace:*",
    "@atc/entity-graph": "workspace:*",
    "@atc/entity-correlation": "workspace:*",
    "@atc/medical-intelligence": "workspace:*",
    "@atc/vehicle-simulation": "workspace:*",
    "@atc/market-runtime": "workspace:*",
    "@atc/faction-runtime": "workspace:*",
    "@atc/task-runtime": "workspace:*",
    "@atc/event-store": "workspace:*",
    "@atc/operations": "workspace:*",
    "@atc/runtime-node": "workspace:*",
    "fastify": "^5.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@atc/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
