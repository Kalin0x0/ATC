# ======================================
# ATC Environment Configuration
# Copy this to .env and fill in values
# NEVER commit .env to git
# ======================================

# ── Application ──────────────────────
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ── API Server ───────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# ── FiveM ↔ API Authentication ───────
ATC_SERVER_TOKEN=          # Generate with: openssl rand -hex 32
ATC_SERVER_ID=atc-main-01  # Unique ID per FiveM server instance
ATC_API_URL=http://localhost:3001

# ── MariaDB ──────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=atc
DB_USER=atc_api
DB_PASSWORD=               # Use a strong password
DB_ROOT_PASSWORD=          # Root password (only for Docker init)
DB_POOL_MAX=20
DB_POOL_MIN=5

# ── Redis ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=            # Leave empty for no auth in local dev
REDIS_DB=0

# ── Security ─────────────────────────
RISK_AUTO_KICK_THRESHOLD=85
RISK_AUTO_BAN_THRESHOLD=100
RISK_NOTIFY_ADMIN_THRESHOLD=60
FIREWALL_LOG_UNKNOWN_EVENTS=true
FIREWALL_UNKNOWN_EVENT_KICK_THRESHOLD=10

# ── Economy Guards ───────────────────
ECONOMY_FRAUD_LARGE_TRANSFER=500000
ECONOMY_FRAUD_RAPID_COUNT=10
ECONOMY_FRAUD_RAPID_WINDOW_MS=60000

# ── Localization ─────────────────────
DEFAULT_LANGUAGE=en
# Supported: en, de, fa

# ── Object Storage (for evidence bundles) ──
STORAGE_ENDPOINT=          # S3 or MinIO endpoint
STORAGE_BUCKET=atc-evidence
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
