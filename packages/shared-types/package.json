{
  "name": "@atc/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript interfaces and types for ATC",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@atc/tsconfig": "workspace:*",
    "typescript": "^5.5.0"
  }
}
