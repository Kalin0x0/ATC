{
  "name": "@atc/locales",
  "version": "0.1.0",
  "private": true,
  "description": "ATC locale translations — en, de, fa",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./locales/en": "./locales/en.json",
    "./locales/de": "./locales/de.json",
    "./locales/fa": "./locales/fa.json"
  },
  "files": ["dist", "locales"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "locale:check": "node ../../tools/scripts/locale-check.js"
  },
  "dependencies": {
    "@atc/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@atc/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
