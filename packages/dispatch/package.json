{
  "name": "@atc/dispatch",
  "version": "0.1.0",
  "private": true,
  "description": "ATC dispatch calls, incidents, responder assignments and BOLO records",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atc/shared-types": "workspace:*",
    "@atc/telemetry": "workspace:*",
    "@atc/events": "workspace:*",
    "mysql2": "^3.9.0",
    "ulidx": "^2.3.0"
  },
  "devDependencies": {
    "@atc/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
